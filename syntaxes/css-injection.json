{
  "scopeName": "css.injection.stylesheet",
  "injectionSelector": "L:text.xml",
  "patterns": [
    {
      "begin": "(<)(Stylesheet)((?:\\s[^>]*)?>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.xml" },
        "3": { "name": "punctuation.definition.tag.end.xml" }
      },
      "end": "(</)(Stylesheet)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.xml" },
        "3": { "name": "punctuation.definition.tag.end.xml" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        { "include": "source.css" }
      ]
    }
  ]
}
